# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Webhook URL — Railway даст домен автоматически, формат:
# https://your-app.up.railway.app
WEBHOOK_URL=

# Путь для webhook (по умолчанию /webhook)
WEBHOOK_PATH=/webhook

# Порт (Railway задаёт автоматически через $PORT)
PORT=8080

# Путь к SQLite базе
DB_PATH=data.db
